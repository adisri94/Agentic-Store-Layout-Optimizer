{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uv", "run", "uvicorn", "api.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "ui",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uv", "run", "streamlit", "run", "ui/streamlit_app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
