# --- LLM (optional — leave blank for mock mode) ---
ANTHROPIC_API_KEY=

# --- API auth (any string; used for the X-API-Key header) ---
API_KEY=demo-key

# --- LLM model ---
LLM_MODEL=claude-sonnet-4.5

# --- Data ---
DATA_DIR=data

# --- Logging ---
LOG_LEVEL=INFO

# --- Feature flags ---
ENABLE_GOVERNANCE=true
MOCK_LLM=false
